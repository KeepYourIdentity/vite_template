{
	"name": "structural",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"biome-lint": "biome lint .",
		"biome-format": "biome format --write .",
		"biome-check": "biome check --write .",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"test": "vitest",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"sync-check": "run-s lint typecheck",
		"async-check": "concurrently -n \"LINT,TYPECHECK\" -c \"cyan,magenta\" \"npm run lint\" \"npm run typecheck\""
	},
	"dependencies": {
		"@emotion/is-prop-valid": "^1.4.0",
		"axios": "^1.18.1",
		"axios-retry": "^4.5.0",
		"browser-image-compression": "^2.0.2",
		"chart.js": "^4.5.1",
		"color-string": "^2.1.4",
		"file-saver": "^2.0.5",
		"lucide-react": "^1.24.0",
		"md5": "^2.3.0",
		"motion": "^12.42.2",
		"react": "^19.2.7",
		"react-chartjs-2": "^5.3.1",
		"react-dom": "^19.2.7",
		"react-number-format": "^5.4.5",
		"react-router-dom": "^7.18.1",
		"react-select": "^5.10.2",
		"react-toastify": "^11.1.0",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@babel/core": "^7.29.7",
		"@biomejs/biome": "^2.5.3",
		"@eslint/js": "^10.0.1",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/react": "^16.3.2",
		"@types/babel__core": "^7.20.5",
		"@types/file-saver": "^2.0.7",
		"@types/md5": "^2.3.6",
		"@types/node": "^24.13.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^10.0.3",
		"eslint": "^10.6.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"npm-run-all": "^4.1.5",
		"sharp": "^0.34.5",
		"svgo": "^4.0.1",
		"tailwindcss": "^4.3.2",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vite-plugin-image-optimizer": "^2.0.3",
		"vitest": "^4.1.10"
	},
	"overrides": {
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	},
	"allowScripts": {
		"sharp@0.34.5": true
	}
}
